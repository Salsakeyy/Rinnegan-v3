# SPRT match binaries (built locally, platform-specific)
chess-engine/build/engine_v1
chess-engine/build/engine_v2

# CMake state that varies by cmake version / platform
chess-engine/build/CMakeFiles/3.*/
chess-engine/build/CMakeFiles/4.*/
chess-engine/build/CMakeFiles/*/compiler_depend.internal

# fastchess auto-generated
chess-engine/config.json

# Gauntlet harness per-run outputs (PGN + log per anchor)
chess-engine/tests/gauntlet_results/

# Out-of-tree build dirs (PGO orchestration, alternate configs)
chess-engine/build-pgo/
chess-engine/build-pgo-final/
chess-engine/build-nolto/

# Standalone binaries produced by tools/openbench-build.sh
chess-engine/rinnegan
chess-engine/rinnegan-*

# macOS noise
.DS_Store
**/.DS_Store
